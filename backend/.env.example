APP_ENV=development
PORT=8080
DATABASE_URL=postgres://dailychecker:dailychecker@localhost:5433/dailychecker?sslmode=disable
JWT_SECRET=change-me
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h
TIMEZONE=Asia/Jakarta
DIGEST_HOUR=22
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
APP_PUBLIC_URL=http://localhost:5173

# CORS — comma-separated list of allowed origins (default: http://localhost:5173)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Telegram delivery mode: "polling" (default, long-poll loop) or "webhook"
TELEGRAM_MODE=polling
# Public base URL the server is reachable at — only required in webhook mode
# e.g. https://example.com  (the path /api/telegram/webhook is appended automatically)
TELEGRAM_WEBHOOK_URL=
# Shared secret validated in X-Telegram-Bot-Api-Secret-Token on each incoming update
TELEGRAM_WEBHOOK_SECRET=
