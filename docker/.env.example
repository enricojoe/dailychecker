# Compose environment for the full Docker stack (docker/docker-compose.yml).
#
# Copy to docker/.env (gitignored). This single file is used both for ${...}
# interpolation in the compose file AND injected into the db/backend containers
# via `env_file`. `make docker-up` / `make docker-build` auto-copy it if missing.
#
# NOTE: this is for the in-container Docker network. For host dev (`make run`)
# the backend reads backend/.env instead (DATABASE_URL there points at :5433).

# ── Database (postgres container) ──
POSTGRES_DB=dailychecker
POSTGRES_USER=dailychecker
POSTGRES_PASSWORD=dailychecker

# ── Backend (container runtime) ──
APP_ENV=production
PORT=8080
# Inside the compose network Postgres is reached by service name on 5432.
DATABASE_URL=postgres://dailychecker:dailychecker@db:5432/dailychecker?sslmode=disable
JWT_SECRET=change-me-in-prod
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h
TIMEZONE=Asia/Jakarta
DIGEST_HOUR=22
# The browser loads the SPA from :8081 and calls the API cross-origin.
CORS_ALLOWED_ORIGINS=http://localhost:8081
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_MODE=polling
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
APP_PUBLIC_URL=http://localhost:8081

# ── Frontend (build-time; Vite inlines into the bundle) ──
VITE_API_BASE_URL=http://localhost:8080/api
