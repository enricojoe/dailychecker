# Frontend environment — copy this file to .env and fill in values.
# .env is gitignored; .env.example is committed as a template.
#
# Vite only exposes VITE_-prefixed variables to the browser bundle.
# NEVER put backend secrets (JWT secret, bot tokens) here.

# Relative path: the Vite dev server proxies /api -> the backend (see
# vite.config.ts). Works for localhost AND over the LAN with no CORS or
# hardcoded IP. For a separate-origin deployment, set an absolute URL instead,
# e.g. http://localhost:8080/api
VITE_API_BASE_URL=/api
